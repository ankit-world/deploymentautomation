# Copy this file to .env and fill in real values. Never commit the real .env file.
#
# This root .env is also what `docker compose` (infra/docker/docker-compose.yml) reads via
# `env_file:` for the backend service's secrets (MONGODB_URI, MONGODB_DB_NAME, JWT_SECRET,
# OPENAI_API_KEY, OPENAI_BASE_URL) — see root README.md "Local development (Docker)".
# REDIS_URL and NEXT_PUBLIC_API_URL are NOT read from here for Docker Compose: compose sets them
# itself (Docker-internal service name / build-arg respectively — see the comments in
# docker-compose.yml and frontend.Dockerfile for why those two are special-cased).

# MongoDB Atlas connection string
MONGODB_URI=

# MongoDB Atlas database name
MONGODB_DB_NAME=chatapp

# OpenAI API key
OPENAI_API_KEY=

# Secret used to sign JWT access/refresh tokens (generate a long random string)
JWT_SECRET=

# Redis connection string (local: redis://localhost:6379/0, prod: ElastiCache endpoint)
REDIS_URL=

# Frontend: base URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# S3 bucket for file attachments (prod only; local dev uses disk storage)
AWS_S3_BUCKET=
AWS_REGION=
