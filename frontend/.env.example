# Base URL of the FastAPI backend (see ../backend). All frontend fetches use this + credentials:
# 'include' so the backend's httpOnly JWT cookies (access_token/refresh_token) are sent/stored
# automatically - no client-side token handling needed.
#
# Must be NEXT_PUBLIC_* to be readable in the browser (this app calls the backend directly from
# client components, not through a Next.js server proxy).
NEXT_PUBLIC_API_URL=http://localhost:8000
