# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored (see root .gitignore) — never commit it.

# MongoDB Atlas connection string (get this from the Atlas dashboard).
# Do NOT rely on a database name embedded in the URI's path — MONGODB_DB_NAME below is what's
# actually used.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGODB_DB_NAME=chatapp

# Secret used to sign JWT access/refresh tokens. Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Access/refresh token lifetimes (defaults shown; usually fine to leave unset)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (not required until session 02's rate limiting / later session's logout blacklist).
# REDIS_URL=redis://localhost:6379/0

# Origin allowed to make credentialed requests (CORS). Must match where the frontend runs.
FRONTEND_ORIGIN=http://localhost:3000

# --- Session 02 (LLM + files) ---
# API key for the OpenAI-compatible chat completions endpoint.
OPENAI_API_KEY=
# Only needed if using a non-OpenAI, OpenAI-*compatible* gateway (e.g. Euri/Euron) instead of
# api.openai.com directly. Leave unset to use the real OpenAI API.
OPENAI_BASE_URL=
