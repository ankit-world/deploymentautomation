# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored (see root .gitignore) — never commit it.

# MongoDB Atlas connection string (get this from the Atlas dashboard).
# Do NOT rely on a database name embedded in the URI's path — MONGODB_DB_NAME below is what's
# actually used.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGODB_DB_NAME=chatapp

# Secret used to sign JWT access/refresh tokens. Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Access/refresh token lifetimes (defaults shown; usually fine to leave unset)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (optional). Powers session 02's per-user chat rate limiting and a later session's
# logout blacklist. If unset, the app automatically falls back to fakeredis (in-memory, dev
# only) — see app/core/redis_client.py. Set this once real Redis/ElastiCache exists (session 09).
# REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_MAX_REQUESTS=20
# RATE_LIMIT_WINDOW_SECONDS=60

# Origin allowed to make credentialed requests (CORS). Must match where the frontend runs.
FRONTEND_ORIGIN=http://localhost:3000

# --- Session 02 (LLM + files) ---
# API key for the OpenAI-compatible chat completions endpoint.
OPENAI_API_KEY=
# Only needed if using a non-OpenAI, OpenAI-*compatible* gateway (e.g. Euri/Euron) instead of
# api.openai.com directly. Leave unset to use the real OpenAI API.
OPENAI_BASE_URL=
# Model id served by the gateway/API above. Defaults to gpt-4o-mini (verified present,
# non-premium, vision-capable on the Euri gateway — see app/services/llm.py). Don't assume
# other OpenAI model names exist on a non-OpenAI gateway; check GET {OPENAI_BASE_URL}/models.
# OPENAI_MODEL=gpt-4o-mini

# File uploads (optional; defaults shown)
# MAX_UPLOAD_SIZE_MB=20
# UPLOAD_DIR=uploads
# EXTRACTED_TEXT_MAX_CHARS=20000

# S3 file storage (session 08+). Leave unset locally — local-disk storage is used instead.
# S3_BUCKET=
# AWS_REGION=
